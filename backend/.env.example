# Azure DevOps Configuration
# Required for CSV test case generation from work items

# Azure DevOps Organization URL (default: https://dev.azure.com/UPSProd8)
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/UPSProd8

# Azure DevOps Project (default: P8AG_Emp_comms)
AZURE_DEVOPS_PROJECT=P8AG_Emp_comms

# Personal Access Token (PAT) - Required for authentication
# Get your PAT from: https://dev.azure.com/UPSProd8/_usersSettings/tokens
# Required scopes: Work Items (Read & Write), Code (Read)
AZURE_DEVOPS_PAT=your_personal_access_token_here

# Optional: OAuth Token (alternative to PAT)
# AZURE_DEVOPS_OAUTH_TOKEN=

# Optional: Custom test status field (default: Custom.TestStatus)
# AZURE_DEVOPS_TEST_STATUS_FIELD=Custom.TestStatus

# Optional: API Version (default: 7.1)
# AZURE_DEVOPS_API_VERSION=7.1

# Optional: Request timeout in milliseconds (default: 15000)
# AZURE_DEVOPS_TIMEOUT_MS=15000

# Instructions:
# 1. Copy this file to .env (without .example)
# 2. Replace 'your_personal_access_token_here' with your actual PAT
# 3. Restart the backend server
# 4. The CSV test case generation will be available when:
#    - Test Type: "Azure Boards - Work Item Management" is selected
#    - Prompt contains keyword "testcase" or "test case"
